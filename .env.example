# Google Gemini API Key from Google AI Studio
# Get yours here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
# Get these from: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# PostHog Configuration
# Get these from: Project Settings -> Project API Key
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# URL of your new Netlify deployment (e.g., https://your-app.netlify.app)
NEXT_PUBLIC_NETLIFY_URL=https://prompt-mint.netlify.app
